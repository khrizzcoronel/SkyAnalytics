# ============================================================
# SkyAnalytics — Variables de entorno de ejemplo
# Copiar a .env y rellenar con valores reales.
# NUNCA commitear .env con secretos.
# ============================================================

# -----------------------------------------------------------
# Entorno
# -----------------------------------------------------------
NODE_ENV=development
PYTHONUNBUFFERED=1

# -----------------------------------------------------------
# PocketBase
# -----------------------------------------------------------
POCKETBASE_URL=http://pocketbase:8090
POCKETBASE_ADMIN_EMAIL=admin@skyanalytics.dev
POCKETBASE_ADMIN_PASSWORD=cambia_esta_password

# -----------------------------------------------------------
# MonetDB
# -----------------------------------------------------------
MONETDB_HOST=monetdb
MONETDB_PORT=50000
MONETDB_USER=monetdb
MONETDB_PASS=cambia_esta_password_monetdb
MONETDB_DB=demo

# -----------------------------------------------------------
# Backend API
# -----------------------------------------------------------
BACKEND_HOST=backend
BACKEND_PORT=8000

# Clave para firmar JWT emitidos por el backend (login propio)
JWT_SECRET=cambia_este_secret_jwt_32_chars_minimo
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# -----------------------------------------------------------
# Frontend
# -----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090

# -----------------------------------------------------------
# Redis (cache + rate-limit)
# -----------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------
# AWS
# -----------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_ML_BUCKET=skyanalytics-ml
S3_BACKUP_BUCKET=skyanalytics-db-backups

# -----------------------------------------------------------
# Integraciones externas
# -----------------------------------------------------------

# RapidAPI proxy secret (CU-T02)
RAPIDAPI_PROXY_SECRET=

# Slack webhook para alertas (CU-O23 drift, CU-O10 error budget, CU-O13 post-mortem)
SLACK_WEBHOOK_URL=

# Sentry (CU-E03, CU-O07)
SENTRY_DSN=
SENTRY_TOKEN=

# Stripe (CU-E02)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# HubSpot (CU-T01)
HUBSPOT_API_KEY=

# Typeform / Google Forms para eNPS (CU-E06)
TYPEFORM_API_KEY=

# Pinecone / Weaviate para FAQ RAG (CU-O14)
PINECONE_API_KEY=
PINECONE_INDEX=skyanalytics-faq

# Optimizely / VWO para pricing A/B (CU-T10)
AB_PLATFORM_API_KEY=

# GitHub (CU-O11 changelog, CU-O15 sprint webhook, CU-O16 OpenAPI lint, CU-O18 SAST)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# SonarQube / Snyk (CU-O18)
SONAR_TOKEN=
SNYK_TOKEN=

# Infracost (CU-O19, CU-T08)
INFRA_COST_API_KEY=

# Terraform Cloud / GitHub Actions (CU-T03)
TERRAFORM_CLOUD_TOKEN=

# -----------------------------------------------------------
# ML / Experimentos
# -----------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=skyanalytics-delay-prediction

# Simulación de EC2 Spot GPU para deep learning (CU-O20)
# Si true, no provisiona infra real; útil para tests/CI.
DL_SIMULATE=true
AWS_EC2_SPOT_INSTANCE_TYPE=p4d.24xlarge

# -----------------------------------------------------------
# Post-Mortem (CU-O13)
# -----------------------------------------------------------
POSTMORTEM_BANNED_NAMES=juan,pedro,maria,carlos

# -----------------------------------------------------------
# Developer Portal (CU-T07)
# -----------------------------------------------------------
MINTLIFY_PROJECT=skyanalytics-docs

# -----------------------------------------------------------
# OpenAPI / SDKs
# -----------------------------------------------------------
OPENAPI_SCHEMA_PATH=docs/openapi.yaml
